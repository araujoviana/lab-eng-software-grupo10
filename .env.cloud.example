# Public URL used by users to access the VM.
# Examples: http://203.0.113.10 or https://zelodesk.example.com
PUBLIC_ORIGIN=http://YOUR_VM_PUBLIC_IP_OR_DOMAIN

# Managed PostgreSQL connection.
DB_HOST=YOUR_MANAGED_POSTGRES_HOST_OR_IP
DB_PORT=5432
DB_NAME=zelodesk
DB_USER=YOUR_DATABASE_USER
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Most managed PostgreSQL services require SSL.
# Use disable only if your provider explicitly does not use SSL.
DB_SSLMODE=require

# HTTP port exposed by the frontend container on the VM.
HTTP_PORT=80

# OAuth client used by the Vue frontend and Spring backend.
CLIENT_ID=zelodesk-client
CLIENT_SECRET=CHANGE_THIS_SECRET

# Keep update for classroom/demo deploys so Spring creates/updates tables.
JPA_DDL_AUTO=update
JWT_DURATION=86400
