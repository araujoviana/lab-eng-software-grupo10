[zelodesk]
zelodesk-ecs ansible_host=CHANGE_ME_ECS_SSH_EIP ansible_user=root ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

[jenkins]
jenkins-ecs ansible_host=CHANGE_ME_JENKINS_SSH_EIP ansible_user=root ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

[all:vars]
ansible_python_interpreter=/usr/bin/python3
