@startuml
skinparam shadowing false
skinparam dpi 140
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20
skinparam BoxPadding 10

title UC-01 - Abrir ticket de zeladoria (MVP)

actor AtorSolicitante as "Solicitante"
boundary "telaAbertura:TelaAberturaTicket" as Tela
entity "solicitante:Solicitante" as Solicitante
entity "ticket:Ticket" as Ticket
entity "categoria:Categoria" as Categoria
entity "localizacao:Localizacao" as Localizacao
entity "anexo:Anexo" as Anexo
entity "auditLog:AuditLog" as AuditLog

AtorSolicitante -> Tela: iniciarAbertura()
Tela -> Solicitante: informarDadosAbertura(titulo, descricao,\ncategoria, localizacao, urgencia, fotoOpcional)

alt dados obrigatorios ausentes
  Solicitante --> Tela: retornarErrosValidacao()
  Tela --> AtorSolicitante: solicitarCorrecao()
else dados validos
  Solicitante -> Categoria: validarCategoria()
  Categoria --> Solicitante: categoriaValida
  Solicitante -> Localizacao: validarLocalizacao()
  Localizacao --> Solicitante: localizacaoValida
  Solicitante -> Ticket: criarTicket(Aberto)
  Solicitante -> Ticket: definirCategoria(categoria)
  Solicitante -> Ticket: definirLocalizacao(localizacao)
  opt foto enviada
    Solicitante -> Anexo: anexarFoto(foto)
    Anexo --> Ticket: vincularAnexo()
  end
  Solicitante -> AuditLog: registrarCriacao(ticket)
  Solicitante --> Tela: exibirProtocolo(ticket)
  Tela --> AtorSolicitante: confirmarAbertura()
end

@enduml
