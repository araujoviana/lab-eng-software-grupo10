@startuml
skinparam shadowing false
skinparam dpi 140
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20
skinparam BoxPadding 10

title UC-03 - Executar atendimento e concluir ticket (MVP)

actor AtorExecutor as "Executor"
boundary "telaExecucao:TelaExecucaoTicket" as Tela
entity "executor:Executor" as Executor
entity "ticket:Ticket" as Ticket
entity "comentario:Comentario" as Comentario
entity "anexo:Anexo" as Anexo
entity "auditLog:AuditLog" as AuditLog
entity "notificacao:Notificacao" as Notificacao

AtorExecutor -> Tela: assumirTicket(ticketId)
Tela -> Executor: iniciarAtendimento(ticketId)
Executor -> Ticket: atualizarStatus(EmExecucao)
Executor -> AuditLog: registrarInicio(ticket)
Executor --> Tela: confirmarInicio()
Tela --> AtorExecutor: exibirTicketEmExecucao()

AtorExecutor -> Tela: registrarAndamento(texto)
Tela -> Executor: registrarComentario(ticket, texto)
Executor -> Comentario: criarComentario(texto)
Comentario --> Ticket: vincularComentario()

AtorExecutor -> Tela: concluirTicket(evidencia)
Tela -> Executor: concluirAtendimento(ticket, evidencia)

alt evidencia ausente
  Executor --> Tela: bloquearConclusao(evidenciaObrigatoria)
  Tela --> AtorExecutor: solicitarEvidencia()
else evidencia enviada
  Executor -> Anexo: anexarEvidencia(evidencia)
  Anexo --> Ticket: vincularEvidencia()
  Executor -> Ticket: atualizarStatus(Concluido)
  Executor -> AuditLog: registrarConclusao(ticket)
  Executor -> Notificacao: notificarSolicitante(ticket)
  Executor -> Notificacao: notificarTriagem(ticket)
  Executor --> Tela: confirmarConclusao()
  Tela --> AtorExecutor: exibirConclusaoRegistrada()
end

@enduml
