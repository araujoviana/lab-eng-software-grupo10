@startuml
skinparam shadowing false
skinparam dpi 140
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20
skinparam BoxPadding 10

title UC-02 - Realizar triagem e atribuir responsavel (MVP)

actor AtorTriagem as "Triagem"
boundary "telaTriagem:TelaTriagem" as Tela
entity "triagem:Triagem" as Triagem
entity "ticket:Ticket" as Ticket
entity "prioridade:Prioridade" as Prioridade
entity "executor:Executor" as Executor
entity "auditLog:AuditLog" as AuditLog

AtorTriagem -> Tela: selecionarTicketPendente(ticketId)
Tela -> Triagem: iniciarTriagem(ticketId)
Triagem -> Ticket: carregarDadosParaTriagem(ticketId)
Ticket --> Triagem: dadosTicket

alt informacao insuficiente
  Triagem -> Ticket: atualizarStatus(AguardandoSolicitante)
  Triagem -> AuditLog: registrarSolicitacaoComplemento(ticket)
  Triagem --> Tela: informarComplementoSolicitado()
else triagem completa
  Triagem -> Prioridade: definirPrioridade(ticket, nivel)
  Prioridade --> Triagem: prioridadeDefinida
  Triagem -> Executor: selecionarResponsavel(ticket)
  Executor --> Triagem: responsavelSelecionado
  Triagem -> Ticket: atribuirResponsavel(executor)
  Triagem -> Ticket: atualizarStatus(EmExecucao)
  Triagem -> AuditLog: registrarAtribuicao(ticket, executor)
  Triagem --> Tela: confirmarAtribuicao()
end

Tela --> AtorTriagem: exibirResultadoTriagem()

@enduml
