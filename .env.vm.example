# Public URL used by users to open the VM.
# Example: http://203.0.113.10
PUBLIC_ORIGIN=http://YOUR_VM_PUBLIC_IP_OR_DOMAIN

# Local PostgreSQL container credentials.
POSTGRES_DB=zelodesk
POSTGRES_USER=zelodesk
POSTGRES_PASSWORD=CHANGE_THIS_DATABASE_PASSWORD

# HTTP port exposed by the frontend container on the VM.
HTTP_PORT=80

# OAuth client used by the Vue frontend and Spring backend.
CLIENT_ID=zelodesk-client
CLIENT_SECRET=zelodesk-secret

# Keep update for classroom/demo deploys so Spring creates/updates tables.
JPA_DDL_AUTO=update
JWT_DURATION=86400
